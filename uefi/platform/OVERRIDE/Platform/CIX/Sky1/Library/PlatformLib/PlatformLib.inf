  gArmTokenSpaceGuid.PcdSystemMemorySize
  gArmPlatformTokenSpaceGuid.PcdArmLcdDdrFrameBufferBase
  gArmPlatformTokenSpaceGuid.PcdArmLcdDdrFrameBufferSize

[Pcd]
  gEfiMdeModulePkgTokenSpaceGuid.PcdSerialClockRate
  gCixPlatformTokenSpaceGuid.PcdReservedSecureMemoryBase
  gCixPlatformTokenSpaceGuid.PcdReservedSecureMemorySize
  gCixPlatformTokenSpaceGuid.PcdReservedShareMemoryBase
  gCixPlatformTokenSpaceGuid.PcdReservedShareMemorySize
  gCixTokenSpaceGuid.PcdCixApToTfaMailBoxBase
  gCixTokenSpaceGuid.PcdCixApToTfaMailBoxSize
